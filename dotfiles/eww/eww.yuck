(defwidget bar []
  (box
    :class "bar"
    :orientation "h"
    :halign "fill"
    :hexpand true

    (label
      :text "Hello from Eww")))
      

(defwindow bar
  :monitor 0
  :geometry (geometry
    :x "0%"
    :y "0px"
    :width "100%"
    :height "30px"
    :anchor "top center")

  :stacking "fg"
  :windowtype "dock"
  :reserve (struts :side "top" :distance "30px")
  :wm-ignore false

  (bar))
